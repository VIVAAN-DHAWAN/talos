{
  "name": "talos",
  "version": "2.0.0",
  "private": true,
  "description": "Talos — repo health dashboard, dead-code scanner, safe cleanup, and panic-recovery tooling.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "scan:knip": "knip",
    "scan:depcheck": "depcheck --json"
  },
  "dependencies": {
    "express": "^4.21.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.61.0",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.5",
    "@vitest/coverage-v8": "^2.1.8",
    "depcheck": "^1.4.7",
    "eslint": "^9.17.0",
    "knip": "^5.42.2",
    "playwright": "^1.49.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.61.1",
    "vitest": "^2.1.8"
  }
}
